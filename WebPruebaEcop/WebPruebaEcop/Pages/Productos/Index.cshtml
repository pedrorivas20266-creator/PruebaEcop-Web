@page
@model WebPruebaEcop.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Gesti¾n de Productos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-shopping-cart"></i>
                <h2>Sistema ECOP</h2>
            </div>

            <nav class="sidebar-nav">
                <ul>
                    <li>
                        <a asp-page="/Index" class="nav-link">
                            <i class="fas fa-home"></i>
                            <span>Inicio</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Productos/Index" class="nav-link active">
                            <i class="fas fa-box"></i>
                            <span>Productos</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Clientes/Index" class="nav-link">
                            <i class="fas fa-users"></i>
                            <span>Clientes</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Pedidos/Index" class="nav-link">
                            <i class="fas fa-file-invoice"></i>
                            <span>Pedidos</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <i class="fas fa-user-circle"></i>
                    <span>Usuario</span>
                </div>
                <form method="post" asp-page="/Index" asp-page-handler="Logout">
                    <button type="submit" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Cerrar Sesi¾n</span>
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-container">
                <div class="page-header">
                    <h1><i class="fas fa-box"></i> ABM Productos</h1>
                    <button class="btn btn-primary" onclick="openProductoModal()">
                        <i class="fas fa-plus"></i> Nuevo Producto
                    </button>
                </div>

                <div class="search-section">
                    <form method="get" class="search-form">
                        <input type="text" 
                               name="busqueda" 
                               placeholder="Buscar por c¾digo, descripci¾n o c¾digo de barra..." 
                               value="@Model.Busqueda"
                               class="form-control search-input" />
                        <button type="submit" class="btn btn-secondary">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                    </form>
                </div>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>C¾digo</th>
                                <th>C¾digo Barra</th>
                                <th>Descripci¾n</th>
                                <th>CategorĒa</th>
                                <th>Unidad Medida</th>
                                <th>Costo</th>
                                <th>Precio</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var producto in Model.Productos)
                            {
                                <tr>
                                    <td>@producto.NumProducto</td>
                                    <td>@producto.CodigoBarra</td>
                                    <td>@producto.DesProducto</td>
                                    <td>@producto.DesCategoria</td>
                                    <td>@producto.DesUnidadMedida</td>
                                    <td>@producto.CostoPromedio?.ToString("N2")</td>
                                    <td>@producto.PrecioVenta.ToString("N2")</td>
                                    <td>
                                        <span class="badge @(producto.Activo ? "badge-success" : "badge-danger")">
                                            @(producto.Activo ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn-icon btn-edit" 
                                                onclick="editProducto(@producto.CodProducto)"
                                                title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn-icon btn-delete" 
                                                onclick="deleteProducto(@producto.CodProducto, '@producto.DesProducto')"
                                                title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (!Model.Productos.Any())
                    {
                        <div class="no-data">
                            <i class="fas fa-inbox"></i>
                            <p>No se encontraron productos</p>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>

    <div id="productoModal" class="modal">
        <div class="modal-content modal-lg">
            <div class="modal-header">
                <h2 id="modalTitle">Nuevo Producto</h2>
                <button class="modal-close" onclick="closeProductoModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="productoForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="codProducto" />
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label>C¾digo de Barra *</label>
                            <input type="text" id="codigoBarra" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label>Descripci¾n *</label>
                            <input type="text" id="desProducto" class="form-control" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>CategorĒa *</label>
                            <select id="codCategoria" class="form-control" required>
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Unidad de Medida *</label>
                            <select id="codUnidadMedida" class="form-control" required>
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>IVA *</label>
                            <select id="codIva" class="form-control" required>
                                <option value="1">10%</option>
                                <option value="2">5%</option>
                                <option value="3">Exento</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Fecha Ingreso</label>
                            <input type="date" id="fechaIngreso" class="form-control" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Costo *</label>
                            <input type="number" id="costo" class="form-control" step="0.01" min="0" required />
                        </div>
                        <div class="form-group">
                            <label>Precio de Venta *</label>
                            <input type="number" id="precioVenta" class="form-control" step="0.01" min="0" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>
                                <input type="checkbox" id="activo" checked /> Activo
                            </label>
                        </div>
                        <div class="form-group">
                            <label>
                                <input type="checkbox" id="descuentaStock" /> Descuenta Stock
                            </label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeProductoModal()">Cancelar</button>
                <button class="btn btn-primary" onclick="saveProducto()">Guardar</button>
            </div>
        </div>
    </div>

    <div id="toastContainer" class="toast-container"></div>
    <div id="modalContainer" class="modal-container"></div>

    <script src="~/js/site.js"></script>
    <script src="~/js/toast.js"></script>
    <script src="~/js/modal.js"></script>
    <script src="~/js/productos.js"></script>
</body>
</html>