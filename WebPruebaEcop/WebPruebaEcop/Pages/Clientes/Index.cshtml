@page
@model IndexModel
@{
    ViewData["Title"] = "Gesti¾n de Clientes";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-shopping-cart"></i>
                <h2>Sistema ECOP</h2>
            </div>

            <nav class="sidebar-nav">
                <ul>
                    <li>
                        <a asp-page="/Index" class="nav-link">
                            <i class="fas fa-home"></i>
                            <span>Inicio</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Productos/Index" class="nav-link">
                            <i class="fas fa-box"></i>
                            <span>Productos</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Clientes/Index" class="nav-link active">
                            <i class="fas fa-users"></i>
                            <span>Clientes</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Pedidos/Index" class="nav-link">
                            <i class="fas fa-file-invoice"></i>
                            <span>Pedidos</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <i class="fas fa-user-circle"></i>
                    <span>Usuario</span>
                </div>
                <form method="post" asp-page="/Index" asp-page-handler="Logout">
                    <button type="submit" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Cerrar Sesi¾n</span>
                    </button>
                </form>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-container">
                <div class="page-header">
                    <h1><i class="fas fa-users"></i> ABM Clientes</h1>
                    <button class="btn btn-primary" onclick="openClienteModal()">
                        <i class="fas fa-plus"></i> Nuevo Cliente
                    </button>
                </div>

                <div class="search-section">
                    <form method="get" class="search-form">
                        <input type="text" 
                               name="busqueda" 
                               placeholder="Buscar por nombre, apellido o documento..." 
                               value="@Model.Busqueda"
                               class="form-control search-input" />
                        <button type="submit" class="btn btn-secondary">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                    </form>
                </div>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>C¾digo</th>
                                <th>Nombres</th>
                                <th>Apellidos</th>
                                <th>Documento</th>
                                <th>Telķfono</th>
                                <th>Email</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in Model.Clientes)
                            {
                                <tr>
                                    <td>@cliente.NumCliente</td>
                                    <td>@cliente.Nombres</td>
                                    <td>@cliente.Apellidos</td>
                                    <td>@cliente.NumeroDocumento</td>
                                    <td>@cliente.NumeroTelefono</td>
                                    <td>@cliente.Correo</td>
                                    <td>
                                        <span class="badge @(cliente.Activo ? "badge-success" : "badge-danger")">
                                            @(cliente.Activo ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn-icon btn-edit" 
                                                onclick="editCliente(@cliente.CodCliente)"
                                                title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn-icon btn-delete" 
                                                onclick="deleteCliente(@cliente.CodCliente, '@cliente.Nombres @cliente.Apellidos')"
                                                title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <div id="clienteModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">Nuevo Cliente</h2>
                <button class="modal-close" onclick="closeClienteModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="clienteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="codCliente" />
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label>Nombres *</label>
                            <input type="text" id="nombres" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label>Apellidos *</label>
                            <input type="text" id="apellidos" class="form-control" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Tipo Documento</label>
                            <select id="codTipoDocumento" class="form-control">
                                <option value="1">Cķdula</option>
                                <option value="2">RUC</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>N·mero Documento *</label>
                            <input type="text" id="numeroDocumento" class="form-control" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Telķfono</label>
                            <input type="text" id="numeroTelefono" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="correo" class="form-control" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Direcci¾n</label>
                        <textarea id="direccion" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label>
                            <input type="checkbox" id="activo" checked /> Activo
                        </label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeClienteModal()">Cancelar</button>
                <button class="btn btn-primary" onclick="saveCliente()">Guardar</button>
            </div>
        </div>
    </div>

    <div id="toastContainer" class="toast-container"></div>
    <div id="modalContainer" class="modal-container"></div>

    <script src="~/js/site.js"></script>
    <script src="~/js/toast.js"></script>
    <script src="~/js/modal.js"></script>
    <script src="~/js/clientes.js"></script>
</body>
</html>